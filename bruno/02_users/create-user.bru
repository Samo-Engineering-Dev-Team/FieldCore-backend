meta {
  name: Create User
  type: http
  seq: 1
}

post {
  url: {{base_url}}/users/
  body: json
  auth: bearer
}
body:json {
  {
    "name": "John",
    "surname": "Doe",
    "email": "john.doe@example.com",
    "password": "password123",
    "role": "noc"
  }
}

auth:bearer {
  token: {{token}}
}
