meta {
  name: Create Route Patrol
  type: http
  seq: 1
}

post {
  url: {{base_url}}/route-patrols/
  body: json
  auth: bearer
}
body:json {
  {
    "technician_id": "{{technician_id}}",
    "site_id": "{{site_id}}",
    "route_km": 12.5,
    "observations": "No visible damage along the route. Vegetation encroachment at km 4.",
    "patrol_date": "2026-03-24"
  }
}

auth:bearer {
  token: {{token}}
}
