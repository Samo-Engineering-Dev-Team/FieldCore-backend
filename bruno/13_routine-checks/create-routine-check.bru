meta {
  name: Create Routine Check
  type: http
  seq: 1
}

post {
  url: {{base_url}}/routine-checks/
  body: json
  auth: bearer
}
body:json {
  {
    "report_id": "{{report_id}}",
    "cables_intact": true,
    "power_supply_ok": true,
    "signal_levels_ok": false,
    "notes": "Signal levels below threshold at port 3"
  }
}

auth:bearer {
  token: {{token}}
}
