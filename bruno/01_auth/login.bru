meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{base_url}}/auth/login
  body: form-urlencoded
  auth: none
}

body:form-urlencoded {
  username: admin@samotelecoms.co.za
  password: Admin@1234
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("token", res.body.access_token);
  }
}
