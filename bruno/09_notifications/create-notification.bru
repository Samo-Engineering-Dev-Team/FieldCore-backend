meta {
  name: Create Notification
  type: http
  seq: 1
}

post {
  url: {{base_url}}/notifications/
  body: json
  auth: bearer
}
body:json {
  {
    "user_id": "{{user_id}}",
    "title": "New Incident Assigned",
    "message": "A major incident has been assigned to your team.",
    "priority": "high"
  }
}

auth:bearer {
  token: {{token}}
}
